---
import Layout from "../layouts/main.astro"
import Background from "../components/custom/Background.tsx"
import MainContent from "../components/custom/MainContent.tsx"
import AppContainer from "../components/custom/AppContainer.tsx"
import Header from "@/components/custom/Header.astro"
import Footer from "@/components/custom/Footer.tsx"
---

<Layout title="AuroraPlay">
  <AppContainer client:load>
    <Background client:load />
    <Header isLogoExpanded={true} />
    <main class="flex flex-1 items-center justify-center">
      <MainContent client:load />
    </main>
    <Footer client:load />
  </AppContainer>
</Layout>
